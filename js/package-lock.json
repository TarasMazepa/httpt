{
  "name": "httpt-js-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "httpt-js-workspace",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@httpt/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@httpt/core": {
      "resolved": "packages/core",
      "link": true
    },
    "packages/cli": {
      "name": "@httpt/cli",
      "version": "1.0.0",
      "license": "ISC",
      "bin": {
        "httpt": "src/bin.js"
      },
      "devDependencies": {}
    },
    "packages/core": {
      "name": "@httpt/core",
      "version": "1.0.0",
      "license": "ISC"
    }
  }
}
